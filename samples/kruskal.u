// Algoritmo de Kruskal — Árvore Geradora Mínima (MST)
//
// Grafo de 5 nós (0–4) com 7 arestas:
//   0-1:10  0-2:6  0-3:5  1-3:15  2-3:4  1-4:12  3-4:8
//
// Union-Find representado como mapa { n0, n1, n2, n3, n4 }
// passado funcionalmente — sem mutação global, sem índice de lista.

// Encontra a raiz do nó par.x no mapa de pais par.p
find: [par] {
    raiz: match par.x {
        0: par.p.n0
        1: par.p.n1
        2: par.p.n2
        3: par.p.n3
        _: par.p.n4
    }
    match raiz == par.x {
        true: raiz
        _: find[{ x: raiz, p: par.p }]
    }
}

// Une os componentes de par.u e par.v, retorna novo mapa de pais
unir: [par] {
    ru: find[{ x: par.u, p: par.p }]
    rv: find[{ x: par.v, p: par.p }]
    match ru {
        0: { n0: rv,       n1: par.p.n1, n2: par.p.n2, n3: par.p.n3, n4: par.p.n4 }
        1: { n0: par.p.n0, n1: rv,       n2: par.p.n2, n3: par.p.n3, n4: par.p.n4 }
        2: { n0: par.p.n0, n1: par.p.n1, n2: rv,       n3: par.p.n3, n4: par.p.n4 }
        3: { n0: par.p.n0, n1: par.p.n1, n2: par.p.n2, n3: rv,       n4: par.p.n4 }
        _: { n0: par.p.n0, n1: par.p.n1, n2: par.p.n2, n3: par.p.n3, n4: rv       }
    }
}

"=== Kruskal — Árvore Geradora Mínima ===" -> out
"Grafo: 5 nós  |  Arestas ordenadas por peso" -> out
"" -> out

p: { n0: 0, n1: 1, n2: 2, n3: 3, n4: 4 }
pesoTotal: 0

// Aresta (2–3, peso 4)
ru: find[{ x: 2, p: p }]
rv: find[{ x: 3, p: p }]
d: ru != rv
match d {
    true: "  (2–3) peso  4  → INCLUÍDA" -> out
    _:    "  (2–3) peso  4  → ignorada (ciclo)" -> out
}
p: match d { true: unir[{ u: 2, v: 3, p: p }]  _: p }
pesoTotal: match d { true: pesoTotal + 4  _: pesoTotal }

// Aresta (0–3, peso 5)
ru: find[{ x: 0, p: p }]
rv: find[{ x: 3, p: p }]
d: ru != rv
match d {
    true: "  (0–3) peso  5  → INCLUÍDA" -> out
    _:    "  (0–3) peso  5  → ignorada (ciclo)" -> out
}
p: match d { true: unir[{ u: 0, v: 3, p: p }]  _: p }
pesoTotal: match d { true: pesoTotal + 5  _: pesoTotal }

// Aresta (0–2, peso 6)
ru: find[{ x: 0, p: p }]
rv: find[{ x: 2, p: p }]
d: ru != rv
match d {
    true: "  (0–2) peso  6  → INCLUÍDA" -> out
    _:    "  (0–2) peso  6  → ignorada (ciclo)" -> out
}
p: match d { true: unir[{ u: 0, v: 2, p: p }]  _: p }
pesoTotal: match d { true: pesoTotal + 6  _: pesoTotal }

// Aresta (3–4, peso 8)
ru: find[{ x: 3, p: p }]
rv: find[{ x: 4, p: p }]
d: ru != rv
match d {
    true: "  (3–4) peso  8  → INCLUÍDA" -> out
    _:    "  (3–4) peso  8  → ignorada (ciclo)" -> out
}
p: match d { true: unir[{ u: 3, v: 4, p: p }]  _: p }
pesoTotal: match d { true: pesoTotal + 8  _: pesoTotal }

// Aresta (0–1, peso 10)
ru: find[{ x: 0, p: p }]
rv: find[{ x: 1, p: p }]
d: ru != rv
match d {
    true: "  (0–1) peso 10  → INCLUÍDA" -> out
    _:    "  (0–1) peso 10  → ignorada (ciclo)" -> out
}
p: match d { true: unir[{ u: 0, v: 1, p: p }]  _: p }
pesoTotal: match d { true: pesoTotal + 10  _: pesoTotal }

// Aresta (1–4, peso 12)
ru: find[{ x: 1, p: p }]
rv: find[{ x: 4, p: p }]
d: ru != rv
match d {
    true: "  (1–4) peso 12  → INCLUÍDA" -> out
    _:    "  (1–4) peso 12  → ignorada (ciclo)" -> out
}
p: match d { true: unir[{ u: 1, v: 4, p: p }]  _: p }
pesoTotal: match d { true: pesoTotal + 12  _: pesoTotal }

// Aresta (1–3, peso 15)
ru: find[{ x: 1, p: p }]
rv: find[{ x: 3, p: p }]
d: ru != rv
match d {
    true: "  (1–3) peso 15  → INCLUÍDA" -> out
    _:    "  (1–3) peso 15  → ignorada (ciclo)" -> out
}
p: match d { true: unir[{ u: 1, v: 3, p: p }]  _: p }
pesoTotal: match d { true: pesoTotal + 15  _: pesoTotal }

"" -> out
"Peso total da MST: {pesoTotal}" -> out
