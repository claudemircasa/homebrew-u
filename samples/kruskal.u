{%
  Algoritmo de Kruskal — Árvore Geradora Mínima (MST)
  Grafo de 5 nós (0–4) com 7 arestas:
    0-1:10  0-2:6  0-3:5  1-3:15  2-3:4  1-4:12  3-4:8
  Union-Find representado como mapa { n0..n4 } — sem mutação global.
%}

// Encontra a raiz do nó x no mapa de pais p
find: [x, p] {
    raiz: match x {
        0: p.n0
        1: p.n1
        2: p.n2
        3: p.n3
        _: p.n4
    }
    match raiz == x {
        true: raiz
        _: find[raiz, p]
    }
}

// Une os componentes de u e v, retorna novo mapa de pais
unir: [u, v, p] {
    ru: find[u, p]
    rv: find[v, p]
    match ru {
        0: { n0: rv,   n1: p.n1, n2: p.n2, n3: p.n3, n4: p.n4 }
        1: { n0: p.n0, n1: rv,   n2: p.n2, n3: p.n3, n4: p.n4 }
        2: { n0: p.n0, n1: p.n1, n2: rv,   n3: p.n3, n4: p.n4 }
        3: { n0: p.n0, n1: p.n1, n2: p.n2, n3: rv,   n4: p.n4 }
        _: { n0: p.n0, n1: p.n1, n2: p.n2, n3: p.n3, n4: rv   }
    }
}

"=== Kruskal — Árvore Geradora Mínima ===" -> out
"Grafo: 5 nós  |  Arestas ordenadas por peso" -> out
"" -> out

p: { n0: 0, n1: 1, n2: 2, n3: 3, n4: 4 }
pesoTotal: 0

// Aresta (2–3, peso 4)
d: find[2, p] != find[3, p]
match d { true: "  (2–3) peso  4  → INCLUÍDA" -> out  _: "  (2–3) peso  4  → ignorada (ciclo)" -> out }
p: match d { true: unir[2, 3, p]  _: p }
pesoTotal: match d { true: pesoTotal + 4  _: pesoTotal }

// Aresta (0–3, peso 5)
d: find[0, p] != find[3, p]
match d { true: "  (0–3) peso  5  → INCLUÍDA" -> out  _: "  (0–3) peso  5  → ignorada (ciclo)" -> out }
p: match d { true: unir[0, 3, p]  _: p }
pesoTotal: match d { true: pesoTotal + 5  _: pesoTotal }

// Aresta (0–2, peso 6)
d: find[0, p] != find[2, p]
match d { true: "  (0–2) peso  6  → INCLUÍDA" -> out  _: "  (0–2) peso  6  → ignorada (ciclo)" -> out }
p: match d { true: unir[0, 2, p]  _: p }
pesoTotal: match d { true: pesoTotal + 6  _: pesoTotal }

// Aresta (3–4, peso 8)
d: find[3, p] != find[4, p]
match d { true: "  (3–4) peso  8  → INCLUÍDA" -> out  _: "  (3–4) peso  8  → ignorada (ciclo)" -> out }
p: match d { true: unir[3, 4, p]  _: p }
pesoTotal: match d { true: pesoTotal + 8  _: pesoTotal }

// Aresta (0–1, peso 10)
d: find[0, p] != find[1, p]
match d { true: "  (0–1) peso 10  → INCLUÍDA" -> out  _: "  (0–1) peso 10  → ignorada (ciclo)" -> out }
p: match d { true: unir[0, 1, p]  _: p }
pesoTotal: match d { true: pesoTotal + 10  _: pesoTotal }

// Aresta (1–4, peso 12)
d: find[1, p] != find[4, p]
match d { true: "  (1–4) peso 12  → INCLUÍDA" -> out  _: "  (1–4) peso 12  → ignorada (ciclo)" -> out }
p: match d { true: unir[1, 4, p]  _: p }
pesoTotal: match d { true: pesoTotal + 12  _: pesoTotal }

// Aresta (1–3, peso 15)
d: find[1, p] != find[3, p]
match d { true: "  (1–3) peso 15  → INCLUÍDA" -> out  _: "  (1–3) peso 15  → ignorada (ciclo)" -> out }
p: match d { true: unir[1, 3, p]  _: p }
pesoTotal: match d { true: pesoTotal + 15  _: pesoTotal }

"" -> out
"Peso total da MST: {pesoTotal}" -> out
