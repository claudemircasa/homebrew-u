{%
  Mergesort em U (top-down)
  Array de 5 elementos representado como mapa { v0..v4 }.
  Usa `and` para `done`, `when` para `take_from_left`, `div` para `mid`,
  block arms para lazy eval sem guards manuais.
%}

// Retorna arr[i]  (i em 0..4)
get: [i, arr] {
    match i {
        0: arr.v0
        1: arr.v1
        2: arr.v2
        3: arr.v3
        _: arr.v4
    }
}

// Retorna novo array com arr[i] = val
set: [i, val, arr] {
    match i {
        0: { v0: val,    v1: arr.v1, v2: arr.v2, v3: arr.v3, v4: arr.v4 }
        1: { v0: arr.v0, v1: val,    v2: arr.v2, v3: arr.v3, v4: arr.v4 }
        2: { v0: arr.v0, v1: arr.v1, v2: val,    v3: arr.v3, v4: arr.v4 }
        3: { v0: arr.v0, v1: arr.v1, v2: arr.v2, v3: val,    v4: arr.v4 }
        _: { v0: arr.v0, v1: arr.v1, v2: arr.v2, v3: arr.v3, v4: val    }
    }
}

// Merge recursivo: intercala arr[lo..mid] e arr[mid+1..hi] em out.
// i = ponteiro esquerdo, j = ponteiro direito, k = posição de escrita.
merge_step: [arr, lo, mid, hi, i, j, k, acc] {
    done: i > mid and j > hi
    match done {
        true: acc
        _: {
            left_done:  i > mid
            right_done: j > hi
            val_i: get[i, arr]
            val_j: get[j, arr]
            take_from_left: match 0 {
                when left_done:  false
                when right_done: true
                _: val_i <= val_j
            }
            val_to_write: match take_from_left { true: val_i _: val_j }
            new_i:        match take_from_left { true: i + 1 _: i     }
            new_j:        match take_from_left { true: j     _: j + 1 }
            new_acc: set[k, val_to_write, acc]
            merge_step[arr, lo, mid, hi, new_i, new_j, k + 1, new_acc]
        }
    }
}

// Mergesort recursivo. Block arm garante lazy eval — sem guards manuais.
ms: [arr, lo, hi] {
    match lo >= hi {
        true: arr
        _: {
            mid:       (lo + hi) div 2
            arr_left:  ms[arr, lo, mid]
            arr_right: ms[arr_left, mid + 1, hi]
            merge_step[arr_right, lo, mid, hi, lo, mid + 1, lo, arr_right]  // acc starts as arr_right
        }
    }
}

"=== Mergesort ===" -> out
"" -> out

// --- Caso 1: aleatório ---
arr: { v0: 5, v1: 3, v2: 1, v3: 4, v4: 2 }
res: ms[arr, 0, 4]
"Original: [{arr.v0}, {arr.v1}, {arr.v2}, {arr.v3}, {arr.v4}]" -> out
"Ordenado: [{res.v0}, {res.v1}, {res.v2}, {res.v3}, {res.v4}]" -> out
"" -> out

// --- Caso 2: ordem inversa ---
arr: { v0: 9, v1: 7, v2: 5, v3: 3, v4: 1 }
res: ms[arr, 0, 4]
"Original: [{arr.v0}, {arr.v1}, {arr.v2}, {arr.v3}, {arr.v4}]" -> out
"Ordenado: [{res.v0}, {res.v1}, {res.v2}, {res.v3}, {res.v4}]" -> out
"" -> out

// --- Caso 3: já ordenado ---
arr: { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5 }
res: ms[arr, 0, 4]
"Original: [{arr.v0}, {arr.v1}, {arr.v2}, {arr.v3}, {arr.v4}]" -> out
"Ordenado: [{res.v0}, {res.v1}, {res.v2}, {res.v3}, {res.v4}]" -> out
"" -> out

// --- Caso 4: com duplicatas ---
arr: { v0: 3, v1: 1, v2: 3, v3: 2, v4: 1 }
res: ms[arr, 0, 4]
"Original: [{arr.v0}, {arr.v1}, {arr.v2}, {arr.v3}, {arr.v4}]" -> out
"Ordenado: [{res.v0}, {res.v1}, {res.v2}, {res.v3}, {res.v4}]" -> out
