// Mergesort em U
//
// Array de 5 elementos representado como mapa { v0..v4 }.
// O merge lê de um array-fonte (arr) e escreve em um acumulador (out),
// ambos passados separadamente — possível porque mapas são imutáveis.
//
// Limitações contornadas:
//   - Sem acesso a lista por índice: get/set funcionais sobre mapa { v0..v4 }
//   - Sem múltiplos parâmetros: argumentos empacotados em mapa
//   - Bindings avaliados eagerly: cada passo recursivo guardado com match próprio
//   - Sem `and`/`or`: condições compostas decompostas em booleanos + match aninhado
//   - Operadores >= e <=: adicionados ao interpretador (eram tokenizados mas não avaliados)

// Retorna arr[i]  (i deve estar em 0..4)
get: [par] {
    match par.i {
        0: par.arr.v0
        1: par.arr.v1
        2: par.arr.v2
        3: par.arr.v3
        _: par.arr.v4
    }
}

// Retorna novo array com arr[i] = val
set: [par] {
    match par.i {
        0: { v0: par.val, v1: par.arr.v1, v2: par.arr.v2, v3: par.arr.v3, v4: par.arr.v4 }
        1: { v0: par.arr.v0, v1: par.val, v2: par.arr.v2, v3: par.arr.v3, v4: par.arr.v4 }
        2: { v0: par.arr.v0, v1: par.arr.v1, v2: par.val, v3: par.arr.v3, v4: par.arr.v4 }
        3: { v0: par.arr.v0, v1: par.arr.v1, v2: par.arr.v2, v3: par.val, v4: par.arr.v4 }
        _: { v0: par.arr.v0, v1: par.arr.v1, v2: par.arr.v2, v3: par.arr.v3, v4: par.val }
    }
}

// Merge recursivo: intercala arr[lo..mid] e arr[mid+1..hi] em out.
// Lê sempre de `arr` (imutável) e escreve em `out` (acumulador).
// par = { arr, lo, mid, hi, i, j, k, out }
//   i  = ponteiro no lado esquerdo  (inicia em lo)
//   j  = ponteiro no lado direito   (inicia em mid+1)
//   k  = posição de escrita em out  (inicia em lo)
// Retorna out com as posições lo..hi em ordem.
merge_step: [par] {
    left_done:  par.i > par.mid
    right_done: par.j > par.hi
    // done = left_done AND right_done  (sem operador `and` nativo)
    done: match left_done {
        true: right_done
        _: false
    }
    val_i: get[{ i: par.i, arr: par.arr }]
    val_j: get[{ i: par.j, arr: par.arr }]
    take_left_when_both: val_i <= val_j
    // Qual lado consumir neste passo?
    take_from_left: match done {
        true: false
        _: match left_done {
            true: false
            _: match right_done {
                true: true
                _: take_left_when_both
            }
        }
    }
    val_to_write: match take_from_left {
        true: val_i
        _: val_j
    }
    new_i: match take_from_left {
        true: par.i + 1
        _: par.i
    }
    new_j: match take_from_left {
        true: par.j
        _: par.j + 1
    }
    new_out: set[{ i: par.k, val: val_to_write, arr: par.out }]
    // Chamada recursiva apenas no braço `_` — lazy, sem recursão infinita no caso base
    match done {
        true: par.out
        _: merge_step[{ arr: par.arr, lo: par.lo, mid: par.mid, hi: par.hi, i: new_i, j: new_j, k: par.k + 1, out: new_out }]
    }
}

// Mergesort recursivo (top-down)
// par = { arr, lo, hi }
ms: [par] {
    terminado: par.lo >= par.hi
    // Cada binding potencialmente recursivo é guardado com match próprio
    // para evitar avaliação eager causar recursão infinita nos casos base.
    mid: match terminado {
        true: par.lo
        _: floor[(par.lo + par.hi) / 2]
    }
    arr_left: match terminado {
        true: par.arr
        _: ms[{ arr: par.arr, lo: par.lo, hi: mid }]
    }
    arr_right: match terminado {
        true: par.arr
        _: ms[{ arr: arr_left, lo: mid + 1, hi: par.hi }]
    }
    match terminado {
        true: par.arr
        _: merge_step[{ arr: arr_right, lo: par.lo, mid: mid, hi: par.hi, i: par.lo, j: mid + 1, k: par.lo, out: arr_right }]
    }
}

"=== Mergesort ===" -> out
"" -> out

// --- Caso 1: aleatório ---
arr: { v0: 5, v1: 3, v2: 1, v3: 4, v4: 2 }
res: ms[{ arr: arr, lo: 0, hi: 4 }]
p0: arr.v0   p1: arr.v1   p2: arr.v2   p3: arr.v3   p4: arr.v4
r0: res.v0   r1: res.v1   r2: res.v2   r3: res.v3   r4: res.v4
"Original: [{p0}, {p1}, {p2}, {p3}, {p4}]" -> out
"Ordenado: [{r0}, {r1}, {r2}, {r3}, {r4}]" -> out
"" -> out

// --- Caso 2: ordem inversa ---
arr: { v0: 9, v1: 7, v2: 5, v3: 3, v4: 1 }
res: ms[{ arr: arr, lo: 0, hi: 4 }]
p0: arr.v0   p1: arr.v1   p2: arr.v2   p3: arr.v3   p4: arr.v4
r0: res.v0   r1: res.v1   r2: res.v2   r3: res.v3   r4: res.v4
"Original: [{p0}, {p1}, {p2}, {p3}, {p4}]" -> out
"Ordenado: [{r0}, {r1}, {r2}, {r3}, {r4}]" -> out
"" -> out

// --- Caso 3: já ordenado ---
arr: { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5 }
res: ms[{ arr: arr, lo: 0, hi: 4 }]
p0: arr.v0   p1: arr.v1   p2: arr.v2   p3: arr.v3   p4: arr.v4
r0: res.v0   r1: res.v1   r2: res.v2   r3: res.v3   r4: res.v4
"Original: [{p0}, {p1}, {p2}, {p3}, {p4}]" -> out
"Ordenado: [{r0}, {r1}, {r2}, {r3}, {r4}]" -> out
"" -> out

// --- Caso 4: com duplicatas ---
arr: { v0: 3, v1: 1, v2: 3, v3: 2, v4: 1 }
res: ms[{ arr: arr, lo: 0, hi: 4 }]
p0: arr.v0   p1: arr.v1   p2: arr.v2   p3: arr.v3   p4: arr.v4
r0: res.v0   r1: res.v1   r2: res.v2   r3: res.v3   r4: res.v4
"Original: [{p0}, {p1}, {p2}, {p3}, {p4}]" -> out
"Ordenado: [{r0}, {r1}, {r2}, {r3}, {r4}]" -> out
