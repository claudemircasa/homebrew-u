{%
  Algoritmo de Dijkstra — Menor Caminho a partir da Fonte
  Grafo não-dirigido de 5 nós (0–4) com 6 arestas:
    0-1:4  0-2:1  1-2:2  1-3:1  2-3:5  3-4:3
  Estado: dist = { d0..d4 }, vis = { v0..v4 }. INF = 9999.
  Block arm em `dijk` elimina os guards manuais por passo.
%}

// ─── Helpers ──────────────────────────────────────────────────────────────────

get_dist: [i, dist] {
    match i {
        0: dist.d0
        1: dist.d1
        2: dist.d2
        3: dist.d3
        _: dist.d4
    }
}

// ─── Find-min: nó não visitado com menor distância ───────────────────────────

find_min: [dist, vis] {
    c0: match vis.v0 { true: 9999 _: dist.d0 }
    c1: match vis.v1 { true: 9999 _: dist.d1 }
    c2: match vis.v2 { true: 9999 _: dist.d2 }
    c3: match vis.v3 { true: 9999 _: dist.d3 }
    c4: match vis.v4 { true: 9999 _: dist.d4 }

    m01:   match c0 <= c1   { true: c0  _: c1  }
    i01:   match c0 <= c1   { true: 0   _: 1   }
    m012:  match m01 <= c2  { true: m01 _: c2  }
    i012:  match m01 <= c2  { true: i01 _: 2   }
    m0123: match m012 <= c3 { true: m012 _: c3 }
    i0123: match m012 <= c3 { true: i012 _: 3  }

    match m0123 <= c4 { true: i0123 _: 4 }
}

// ─── Set-vis: marca nó como visitado ─────────────────────────────────────────

set_vis: [i, vis] {
    match i {
        0: { v0: true,      v1: vis.v1, v2: vis.v2, v3: vis.v3, v4: vis.v4 }
        1: { v0: vis.v0,    v1: true,   v2: vis.v2, v3: vis.v3, v4: vis.v4 }
        2: { v0: vis.v0,    v1: vis.v1, v2: true,   v3: vis.v3, v4: vis.v4 }
        3: { v0: vis.v0,    v1: vis.v1, v2: vis.v2, v3: true,   v4: vis.v4 }
        _: { v0: vis.v0,    v1: vis.v1, v2: vis.v2, v3: vis.v3, v4: true   }
    }
}

// ─── Relax por nó ─────────────────────────────────────────────────────────────

// Nó 0: arestas → 1 (w=4), → 2 (w=1)
relax0: [dist_u, dist] {
    nd1: match dist_u + 4 < dist.d1 { true: dist_u + 4 _: dist.d1 }
    nd2: match dist_u + 1 < dist.d2 { true: dist_u + 1 _: dist.d2 }
    { d0: dist.d0, d1: nd1, d2: nd2, d3: dist.d3, d4: dist.d4 }
}

// Nó 1: arestas → 0 (w=4), → 2 (w=2), → 3 (w=1)
relax1: [dist_u, dist] {
    nd0: match dist_u + 4 < dist.d0 { true: dist_u + 4 _: dist.d0 }
    nd2: match dist_u + 2 < dist.d2 { true: dist_u + 2 _: dist.d2 }
    nd3: match dist_u + 1 < dist.d3 { true: dist_u + 1 _: dist.d3 }
    { d0: nd0, d1: dist.d1, d2: nd2, d3: nd3, d4: dist.d4 }
}

// Nó 2: arestas → 0 (w=1), → 1 (w=2), → 3 (w=5)
relax2: [dist_u, dist] {
    nd0: match dist_u + 1 < dist.d0 { true: dist_u + 1 _: dist.d0 }
    nd1: match dist_u + 2 < dist.d1 { true: dist_u + 2 _: dist.d1 }
    nd3: match dist_u + 5 < dist.d3 { true: dist_u + 5 _: dist.d3 }
    { d0: nd0, d1: nd1, d2: dist.d2, d3: nd3, d4: dist.d4 }
}

// Nó 3: arestas → 1 (w=1), → 2 (w=5), → 4 (w=3)
relax3: [dist_u, dist] {
    nd1: match dist_u + 1 < dist.d1 { true: dist_u + 1 _: dist.d1 }
    nd2: match dist_u + 5 < dist.d2 { true: dist_u + 5 _: dist.d2 }
    nd4: match dist_u + 3 < dist.d4 { true: dist_u + 3 _: dist.d4 }
    { d0: dist.d0, d1: nd1, d2: nd2, d3: dist.d3, d4: nd4 }
}

// Nó 4: arestas → 3 (w=3)
relax4: [dist_u, dist] {
    nd3: match dist_u + 3 < dist.d3 { true: dist_u + 3 _: dist.d3 }
    { d0: dist.d0, d1: dist.d1, d2: dist.d2, d3: nd3, d4: dist.d4 }
}

// Despacha relaxamento para o nó correto
relax: [u, dist_u, dist] {
    match u {
        0: relax0[dist_u, dist]
        1: relax1[dist_u, dist]
        2: relax2[dist_u, dist]
        3: relax3[dist_u, dist]
        _: relax4[dist_u, dist]
    }
}

// ─── Loop principal de Dijkstra ───────────────────────────────────────────────
// Block arm garante lazy eval — sem guards manuais por passo.
dijk: [dist, vis, step] {
    match step <= 0 {
        true: dist
        _: {
            u:        find_min[dist, vis]
            dist_u:   get_dist[u, dist]
            new_dist: relax[u, dist_u, dist]
            new_vis:  set_vis[u, vis]
            dijk[new_dist, new_vis, step - 1]
        }
    }
}

// ─── Execução ─────────────────────────────────────────────────────────────────

"=== Dijkstra — Menor Caminho ===" -> out
"Grafo: 5 nós  |  0-1:4  0-2:1  1-2:2  1-3:1  2-3:5  3-4:3" -> out
"Fonte: nó 0" -> out
"" -> out

dist_ini: { d0: 0, d1: 9999, d2: 9999, d3: 9999, d4: 9999 }
vis_ini:  { v0: false, v1: false, v2: false, v3: false, v4: false }

res: dijk[dist_ini, vis_ini, 5]

"Distâncias mínimas a partir do nó 0:" -> out
"  nó 0 → {res.d0}" -> out
"  nó 1 → {res.d1}  (caminho: 0→2→1)" -> out
"  nó 2 → {res.d2}  (caminho: 0→2)" -> out
"  nó 3 → {res.d3}  (caminho: 0→2→1→3)" -> out
"  nó 4 → {res.d4}  (caminho: 0→2→1→3→4)" -> out
