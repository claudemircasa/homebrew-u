{%
  Quicksort em U — Particionamento Lomuto
  Array de 5 elementos representado como mapa { v0..v4 } (set funcional).
  Block arm em `qs` elimina os múltiplos guards `match terminado`.
%}

// Retorna arr[i]  (i em 0..4)
get: [i, arr] {
    match i {
        0: arr.v0
        1: arr.v1
        2: arr.v2
        3: arr.v3
        _: arr.v4
    }
}

// Retorna novo array com arr[i] = val
set: [i, val, arr] {
    match i {
        0: { v0: val,    v1: arr.v1, v2: arr.v2, v3: arr.v3, v4: arr.v4 }
        1: { v0: arr.v0, v1: val,    v2: arr.v2, v3: arr.v3, v4: arr.v4 }
        2: { v0: arr.v0, v1: arr.v1, v2: val,    v3: arr.v3, v4: arr.v4 }
        3: { v0: arr.v0, v1: arr.v1, v2: arr.v2, v3: val,    v4: arr.v4 }
        _: { v0: arr.v0, v1: arr.v1, v2: arr.v2, v3: arr.v3, v4: val    }
    }
}

// Troca os elementos nas posições a e b; retorna novo array
swap: [arr, a, b] {
    va:  get[a, arr]
    vb:  get[b, arr]
    tmp: set[a, vb, arr]
    set[b, va, tmp]
}

// Particionamento Lomuto: percorre arr[j] de lo até hi-1.
// Retorna { arr, idx } — arr reorganizado, idx = posição final do pivot.
part: [arr, lo, hi, i, j, pivot] {
    terminado:   j >= hi
    val_j:       get[j, arr]
    elegivel:    val_j <= pivot
    arr_swapped: swap[arr, i + 1, j]
    match terminado {
        true: { arr: arr_swapped, idx: i + 1 }
        _: match elegivel {
            true: part[arr_swapped, lo, hi, i + 1, j + 1, pivot]
            _:    part[arr,         lo, hi, i,     j + 1, pivot]
        }
    }
}

// Quicksort recursivo. Block arm garante lazy eval — sem guards manuais.
qs: [arr, lo, hi] {
    match lo >= hi {
        true: arr
        _: {
            pivot: get[hi, arr]
            p:     part[arr, lo, hi, lo - 1, lo, pivot]
            arr2:  qs[p.arr, lo, p.idx - 1]
            qs[arr2, p.idx + 1, hi]
        }
    }
}

"=== Quicksort ===" -> out
"" -> out

// --- Caso 1: aleatório ---
arr: { v0: 5, v1: 3, v2: 1, v3: 4, v4: 2 }
res: qs[arr, 0, 4]
"Original: [{arr.v0}, {arr.v1}, {arr.v2}, {arr.v3}, {arr.v4}]" -> out
"Ordenado: [{res.v0}, {res.v1}, {res.v2}, {res.v3}, {res.v4}]" -> out
"" -> out

// --- Caso 2: ordem inversa (pior caso para Lomuto) ---
arr: { v0: 9, v1: 7, v2: 5, v3: 3, v4: 1 }
res: qs[arr, 0, 4]
"Original: [{arr.v0}, {arr.v1}, {arr.v2}, {arr.v3}, {arr.v4}]" -> out
"Ordenado: [{res.v0}, {res.v1}, {res.v2}, {res.v3}, {res.v4}]" -> out
"" -> out

// --- Caso 3: já ordenado ---
arr: { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5 }
res: qs[arr, 0, 4]
"Original: [{arr.v0}, {arr.v1}, {arr.v2}, {arr.v3}, {arr.v4}]" -> out
"Ordenado: [{res.v0}, {res.v1}, {res.v2}, {res.v3}, {res.v4}]" -> out
"" -> out

// --- Caso 4: com duplicatas ---
arr: { v0: 3, v1: 1, v2: 3, v3: 2, v4: 1 }
res: qs[arr, 0, 4]
"Original: [{arr.v0}, {arr.v1}, {arr.v2}, {arr.v3}, {arr.v4}]" -> out
"Ordenado: [{res.v0}, {res.v1}, {res.v2}, {res.v3}, {res.v4}]" -> out
