{%
  Busca Binária em U
  Array ordenado de 10 elementos: [2, 5, 8, 12, 16, 23, 38, 56, 72, 91]
  Usa list literal e acesso por índice arr[i] — sem get/set auxiliar.
%}

// Busca binária recursiva
// Retorna o índice do target, ou -1 se não encontrado
busca: [arr, low, high, target] {
    match low > high {
        true: -1
        _: {
            mid: (low + high) div 2
            val: arr[mid]
            match val {
                when val == target: mid
                when val < target:  busca[arr, mid + 1, high, target]
                _:                  busca[arr, low, mid - 1, target]
            }
        }
    }
}

arr: [2, 5, 8, 12, 16, 23, 38, 56, 72, 91]
hi: 9

"=== Busca Binária ===" -> out
"Array: [2, 5, 8, 12, 16, 23, 38, 56, 72, 91]" -> out
"" -> out

r: busca[arr, 0, hi, 2]
match r { when r != -1: "busca( 2): encontrado no índice {r}" -> out  _: "busca( 2): não encontrado" -> out }

r: busca[arr, 0, hi, 23]
match r { when r != -1: "busca(23): encontrado no índice {r}" -> out  _: "busca(23): não encontrado" -> out }

r: busca[arr, 0, hi, 91]
match r { when r != -1: "busca(91): encontrado no índice {r}" -> out  _: "busca(91): não encontrado" -> out }

r: busca[arr, 0, hi, 38]
match r { when r != -1: "busca(38): encontrado no índice {r}" -> out  _: "busca(38): não encontrado" -> out }

r: busca[arr, 0, hi, 7]
match r { when r != -1: "busca( 7): encontrado no índice {r}" -> out  _: "busca( 7): não encontrado" -> out }

r: busca[arr, 0, hi, 100]
match r { when r != -1: "busca(100): encontrado no índice {r}" -> out  _: "busca(100): não encontrado" -> out }
