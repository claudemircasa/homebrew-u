{%
  Insertion Sort em U
  Array de 5 elementos representado como mapa { v0..v4 } (necessário para set funcional).
  Usa multi-param, `and`, block arm, `reduce` e interpolação com acesso a membro.
%}

// Retorna arr[i]  (i em 0..4)
get: [i, arr] {
    match i {
        0: arr.v0
        1: arr.v1
        2: arr.v2
        3: arr.v3
        _: arr.v4
    }
}

// Retorna novo array com arr[i] = val
set: [i, val, arr] {
    match i {
        0: { v0: val,     v1: arr.v1, v2: arr.v2, v3: arr.v3, v4: arr.v4 }
        1: { v0: arr.v0,  v1: val,    v2: arr.v2, v3: arr.v3, v4: arr.v4 }
        2: { v0: arr.v0,  v1: arr.v1, v2: val,    v3: arr.v3, v4: arr.v4 }
        3: { v0: arr.v0,  v1: arr.v1, v2: arr.v2, v3: val,    v4: arr.v4 }
        _: { v0: arr.v0,  v1: arr.v1, v2: arr.v2, v3: arr.v3, v4: val    }
    }
}

// Move arr[j] para a esquerda enquanto arr[j] < arr[j-1].
// `and` garante short-circuit: get[j-1, arr] não é avaliado quando j = 0.
descer: [arr, j] {
    val_j: get[j, arr]
    deve_trocar: j > 0 and val_j < get[j - 1, arr]
    match deve_trocar {
        true: {
            val_prev: get[j - 1, arr]
            tmp:      set[j,     val_prev, arr]
            trocado:  set[j - 1, val_j,   tmp]
            descer[trocado, j - 1]
        }
        _: arr
    }
}

// Insertion Sort: percorre posições 1..4 acumulando o array ordenado
ordenar: [arr] {
    each j in 1..4 reduce acc: arr {
        descer[acc, j]
    }
}

"=== Insertion Sort ===" -> out
"" -> out

// --- Caso 1: aleatório ---
arr: { v0: 5, v1: 3, v2: 1, v3: 4, v4: 2 }
res: ordenar[arr]
"Original: [{arr.v0}, {arr.v1}, {arr.v2}, {arr.v3}, {arr.v4}]" -> out
"Ordenado: [{res.v0}, {res.v1}, {res.v2}, {res.v3}, {res.v4}]" -> out
"" -> out

// --- Caso 2: ordem inversa (pior caso) ---
arr: { v0: 9, v1: 7, v2: 5, v3: 3, v4: 1 }
res: ordenar[arr]
"Original: [{arr.v0}, {arr.v1}, {arr.v2}, {arr.v3}, {arr.v4}]" -> out
"Ordenado: [{res.v0}, {res.v1}, {res.v2}, {res.v3}, {res.v4}]" -> out
"" -> out

// --- Caso 3: já ordenado (melhor caso) ---
arr: { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5 }
res: ordenar[arr]
"Original: [{arr.v0}, {arr.v1}, {arr.v2}, {arr.v3}, {arr.v4}]" -> out
"Ordenado: [{res.v0}, {res.v1}, {res.v2}, {res.v3}, {res.v4}]" -> out
"" -> out

// --- Caso 4: com duplicatas ---
arr: { v0: 3, v1: 1, v2: 3, v3: 2, v4: 1 }
res: ordenar[arr]
"Original: [{arr.v0}, {arr.v1}, {arr.v2}, {arr.v3}, {arr.v4}]" -> out
"Ordenado: [{res.v0}, {res.v1}, {res.v2}, {res.v3}, {res.v4}]" -> out
